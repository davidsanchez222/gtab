#!/usr/bin/env bash
set -euo pipefail

# Workspace directory: override with GTAB_DIR environment variable
BASE_DIR="${GTAB_DIR:-$HOME/.config/gtab}"

mkdir -p "$BASE_DIR"

# Color support: respect NO_COLOR (https://no-color.org) and non-TTY
if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
  BOLD=$'\033[1m'  DIM=$'\033[2m'  ITALIC=$'\033[3m'  RESET=$'\033[0m'
  CYAN=$'\033[36m' GREEN=$'\033[32m' RED=$'\033[31m' YELLOW=$'\033[33m'
else
  BOLD='' DIM='' ITALIC='' RESET=''
  CYAN='' GREEN='' RED='' YELLOW=''
fi

err() { printf '%s\n' "${RED}${BOLD}error:${RESET}${RED} $1${RESET}" >&2; }
ok()  { printf '%s\n' "${GREEN}${BOLD}✓${RESET} $1"; }

usage() {
  local rule='───────────────────────────────────────────────'
  printf ' %s╭%s╮%s\n' "$CYAN" "$rule" "$RESET"
  printf ' %s│%s  %s%sgtab%s — Ghostty Tab Workspace Manager         %s│%s\n' \
    "$CYAN" "$RESET" "$CYAN" "$BOLD" "$RESET" "$CYAN" "$RESET"
  printf ' %s╰%s╯%s\n' "$CYAN" "$rule" "$RESET"
  echo
  printf ' %sUsage:%s\n' "$BOLD" "$RESET"
  printf '   %sgtab%s <%s%sname%s>           Launch a workspace\n' "$BOLD" "$RESET" "$ITALIC" "$YELLOW" "$RESET"
  printf '   %sgtab save%s <%s%sname%s>      Save current Ghostty window\n' "$BOLD" "$RESET" "$ITALIC" "$YELLOW" "$RESET"
  printf '   %sgtab list%s             List all saved workspaces\n' "$BOLD" "$RESET"
  printf '   %sgtab edit%s <%s%sname%s>      Edit a workspace script\n' "$BOLD" "$RESET" "$ITALIC" "$YELLOW" "$RESET"
  printf '   %sgtab remove%s <%s%sname%s>    Remove a workspace\n' "$BOLD" "$RESET" "$ITALIC" "$YELLOW" "$RESET"
  echo
  printf ' %sWorkspaces:%s %s%s%s\n' "$DIM" "$RESET" "$DIM" "$BASE_DIR" "$RESET"
  printf ' %sOverride:%s   %sexport GTAB_DIR=/your/path%s\n' "$DIM" "$RESET" "$DIM" "$RESET"
}

cmd="${1:-}"

case "$cmd" in
  list)
    files=("$BASE_DIR"/*.applescript)
    if [[ ! -e "${files[0]}" ]]; then
      printf ' %sNo workspaces saved.%s\n' "$DIM" "$RESET"
    else
      printf ' %sWorkspaces:%s\n' "$BOLD" "$RESET"
      for f in "${files[@]}"; do
        name=$(basename "$f" .applescript)
        printf '   %s●%s %s%s%s\n' "$CYAN" "$RESET" "$YELLOW" "$name" "$RESET"
      done
    fi
    ;;

  save)
    name="${2:-}"
    [ -n "$name" ] || { err "missing workspace name"; exit 1; }
    file="$BASE_DIR/$name.applescript"

    tmp=$(mktemp /tmp/gtab_XXXXXX)
    cat > "$tmp" <<'ASCRIPT'
set rows to {}
tell application "Ghostty"
  set win to front window
  set n to count of tabs of win
  repeat with i from 1 to n
    set t to tab i of win
    set surf to focused terminal of t
    try
      set wd to working directory of surf
    on error
      set wd to ""
    end try
    set ttl to name of t
    if ttl starts with "⠐ " then set ttl to text 3 thru -1 of ttl
    set end of rows to (wd & "	" & ttl)
  end repeat
end tell
set AppleScript's text item delimiters to linefeed
return rows as text
ASCRIPT
    raw=$(osascript "$tmp" 2>/dev/null)
    rm -f "$tmp"

    [ -n "$raw" ] || { err "could not read Ghostty tabs (make sure Ghostty is the frontmost app)"; exit 1; }

    out='tell application "Ghostty"\n    activate'
    i=0
    while IFS=$'\t' read -r wd title; do
      i=$((i+1))
      [ -z "$wd" ] && wd="$HOME"
      out+="\n\n    set cfg$i to new surface configuration"
      out+="\n    set initial working directory of cfg$i to \"$wd\""
      if [ "$i" -eq 1 ]; then
        out+="\n    set win to new window with configuration cfg$i"
        out+="\n    set term$i to focused terminal of selected tab of win"
      else
        out+="\n    set tab$i to new tab in win with configuration cfg$i"
        out+="\n    set term$i to focused terminal of tab$i"
      fi
      [ -n "$title" ] && out+="\n    perform action \"set_tab_title:$title\" on term$i"
    done <<< "$raw"
    out+="\nend tell"

    printf '%b\n' "$out" > "$file"
    ok "Saved workspace ${YELLOW}\"$name\"${RESET}"
    printf '   %s%s%s\n' "$DIM" "$file" "$RESET"
    ;;

  edit)
    name="${2:-}"
    [ -n "$name" ] || { err "missing workspace name"; exit 1; }
    "${EDITOR:-vim}" "$BASE_DIR/$name.applescript"
    ;;

  remove)
    name="${2:-}"
    [ -n "$name" ] || { err "missing workspace name"; exit 1; }
    file="$BASE_DIR/$name.applescript"
    [ -f "$file" ] || { err "workspace '$name' not found"; exit 1; }
    rm -f "$file"
    ok "Removed workspace ${YELLOW}\"$name\"${RESET}"
    ;;

  ""|--help|-h)
    usage
    [ -z "$cmd" ] && exit 1 || exit 0
    ;;

  *)
    file="$BASE_DIR/$cmd.applescript"
    [ -f "$file" ] || { err "workspace '$cmd' not found — run ${BOLD}gtab list${RESET}${RED} to see available workspaces"; exit 1; }
    printf ' %s▸%s Launching %s"%s"%s...\n' "$CYAN" "$RESET" "$YELLOW" "$cmd" "$RESET"
    osascript "$file"
    ;;
esac
